@echo off
powershell.exe -ExecutionPolicy Bypass -NoProfile -Command "$l=[System.Net.HttpListener]::new();$l.Prefixes.Add('http://+:3000/');$l.Start();$root='C:\Users\appas\OneDrive\Desktop\HouseBath Dashboard';while($l.IsListening){$ctx=$l.GetContext();$p=$ctx.Request.Url.LocalPath;if($p -eq '/'){$p='/index.html'};$f=Join-Path $root ($p.TrimStart('/').Replace('/',[char]92));$r=$ctx.Response;if(Test-Path $f -PathType Leaf){$e=[System.IO.Path]::GetExtension($f).ToLower();$m=if($e -eq '.html'){'text/html;charset=utf-8'}elseif($e -eq '.css'){'text/css;charset=utf-8'}elseif($e -eq '.js'){'application/javascript;charset=utf-8'}else{'text/plain'};$b=[System.IO.File]::ReadAllBytes($f);$r.ContentType=$m;$r.ContentLength64=$b.Length;$r.OutputStream.Write($b,0,$b.Length)}else{$r.StatusCode=404};$r.OutputStream.Close()}"
